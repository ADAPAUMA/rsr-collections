{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "YOUR_RENDER_URL_HERE/api/:path*"
    },
    {
       "source": "/uploads/:path*",
       "destination": "YOUR_RENDER_URL_HERE/uploads/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
